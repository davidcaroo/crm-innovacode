// Clave de cifrado - GENERAR UNA NUEVA CLAVE SEGURA DE 32 CARACTERES
// Puedes usar: openssl rand -base64 32
define('ENCRYPTION_KEY', 'GENERAR_NUEVA_CLAVE_SEGURA_32_CARACTERES');

// Modo de desarrollo - SIEMPRE false EN PRODUCCIÓN
define('DEBUG_MODE', false);

// Configurar reporte de errores para producción
error_reporting(E_ALL & ~E_DEPRECATED & ~E_STRICT & ~E_NOTICE);
ini_set('display_errors', 0);
ini_set('log_errors', 1);
ini_set('error_log', BASE_PATH . '/logs/error.log');

// Custom error handler para evitar mostrar errores en pantalla
set_error_handler(function ($errno, $errstr, $errfile, $errline) {
    if (!(error_reporting() & $errno)) {
        return false;
    }
    
    $logMessage = sprintf(
        "[%s] Error %d: %s in %s on line %d\n",
        date('Y-m-d H:i:s'),
        $errno,
        $errstr,
        $errfile,
        $errline
    );
    
    error_log($logMessage, 3, BASE_PATH . '/logs/error.log');
    
    return true;
});

/**
 * Helper: Función url() para generar URLs del sistema
 */
function url($path = '')
{
    $path = ltrim($path, '/');
    return BASE_URL . '/' . $path;
}

/**
 * Helper: Verificar si hay sesión activa
 */
function isLoggedIn()
{
    return isset($_SESSION['usuario_id']) && !empty($_SESSION['usuario_id']);
}

/**
 * Helper: Obtener ID del usuario en sesión
 */
function getUserId()
{
    return $_SESSION['usuario_id'] ?? null;
}

/**
 * Helper: Obtener rol del usuario en sesión
 */
function getUserRole()
{
    return $_SESSION['usuario_rol'] ?? null;
}

/**
 * Helper: Verificar si el usuario tiene un rol específico
 */
function hasRole($role)
{
    return getUserRole() === $role;
}

/**
 * Helper: Sanitizar entrada de usuario
 */
function sanitize($data)
{
    if (is_array($data)) {
        return array_map('sanitize', $data);
    }
    return htmlspecialchars(strip_tags(trim($data)), ENT_QUOTES, 'UTF-8');
}

/**
 * Configuración de sesión segura para producción
 */
ini_set('session.cookie_httponly', 1);
ini_set('session.cookie_secure', 1); // Solo con HTTPS
ini_set('session.use_strict_mode', 1);
ini_set('session.cookie_samesite', 'Lax');

// Iniciar sesión si no está iniciada
if (session_status() === PHP_SESSION_NONE) {
    session_start();
}

