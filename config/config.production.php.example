define('MODELS_PATH', BASE_PATH . '/models');
define('CONTROLLERS_PATH', BASE_PATH . '/controllers');

// URL base - ACTUALIZAR CON DOMINIO DE PRODUCCIÓN
define('BASE_URL', 'https://crm.bahariaqua.com');

// Configuración de la aplicación
